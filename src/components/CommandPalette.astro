---
import {
  ui,
  webProjects,
  embeddedProjects,
  profile,
  variantPath,
  type Lang,
  type VariantKey,
} from '../data/content';

interface Props {
  lang: Lang;
  variant?: VariantKey;
}
const { lang, variant = 'embedded' } = Astro.props;
const other: Lang = lang === 'fr' ? 'en' : 'fr';

const sections = [
  { label: ui.nav.experience[lang], href: '#experience' },
  { label: ui.nav.embedded[lang], href: '#embedded' },
  { label: ui.nav.web[lang], href: '#web' },
  { label: ui.nav.skills[lang], href: '#skills' },
  { label: ui.nav.contact[lang], href: '#contact' },
];

const projects = [...embeddedProjects, ...webProjects]
  .map((p) => ({ label: p.title, href: p.url ?? p.repo }))
  .filter((p): p is { label: string; href: string } => Boolean(p.href));

const t = {
  placeholder: { fr: 'Rechercher une section, un projet…', en: 'Search a section, a project…' },
  sections: { fr: 'Sections', en: 'Sections' },
  projects: { fr: 'Projets', en: 'Projects' },
  actions: { fr: 'Actions', en: 'Actions' },
  copyEmail: { fr: "Copier l'e-mail", en: 'Copy e-mail' },
  switchLang: { fr: 'English version', en: 'Version française' },
};
---

<div
  id="cmdk"
  class="fixed inset-0 z-[90] hidden items-start justify-center bg-ink/70 p-4 pt-[15vh] backdrop-blur-sm"
>
  <div class="w-full max-w-lg overflow-hidden rounded-xl border border-line bg-card shadow-2xl">
    <input
      id="cmdk-input"
      type="text"
      autocomplete="off"
      spellcheck="false"
      placeholder={t.placeholder[lang]}
      class="w-full border-b border-line bg-transparent px-4 py-3 text-sm text-slate-100 outline-none placeholder:text-slate-500"
    />
    <div id="cmdk-list" class="max-h-80 overflow-y-auto p-2">
      <div data-group>
        <p class="px-3 pb-1 pt-2 font-mono text-xs uppercase tracking-wider text-slate-600">
          {t.sections[lang]}
        </p>
        {
          sections.map((s) => (
            <div data-item>
              <a
                href={s.href}
                data-cmd
                data-label={s.label.toLowerCase()}
                class="flex items-center gap-3 rounded-md px-3 py-2 text-sm text-slate-300 aria-selected:bg-surface aria-selected:text-accent"
              >
                <span class="font-mono text-xs text-slate-600">#</span>
                {s.label}
              </a>
            </div>
          ))
        }
      </div>

      <div data-group>
        <p class="px-3 pb-1 pt-3 font-mono text-xs uppercase tracking-wider text-slate-600">
          {t.projects[lang]}
        </p>
        {
          projects.map((p) => (
            <div data-item>
              <a
                href={p.href}
                target="_blank"
                rel="noopener"
                data-cmd
                data-label={p.label.toLowerCase()}
                class="flex items-center gap-3 rounded-md px-3 py-2 text-sm text-slate-300 aria-selected:bg-surface aria-selected:text-accent"
              >
                <span class="font-mono text-xs text-slate-600">↗</span>
                {p.label}
              </a>
            </div>
          ))
        }
      </div>

      <div data-group>
        <p class="px-3 pb-1 pt-3 font-mono text-xs uppercase tracking-wider text-slate-600">
          {t.actions[lang]}
        </p>
        <div data-item>
          <button
            type="button"
            data-cmd
            data-copy={profile.email}
            data-label={`${t.copyEmail[lang].toLowerCase()} email mail`}
            class="flex w-full items-center gap-3 rounded-md px-3 py-2 text-left text-sm text-slate-300 aria-selected:bg-surface aria-selected:text-accent"
          >
            <span class="font-mono text-xs text-slate-600">@</span>
            {t.copyEmail[lang]}
          </button>
        </div>
        <div data-item>
          <a
            href={profile.github}
            target="_blank"
            rel="noopener"
            data-cmd
            data-label="github"
            class="flex items-center gap-3 rounded-md px-3 py-2 text-sm text-slate-300 aria-selected:bg-surface aria-selected:text-accent"
          >
            <span class="font-mono text-xs text-slate-600">↗</span>
            GitHub
          </a>
        </div>
        <div data-item>
          <a
            href={profile.linkedin}
            target="_blank"
            rel="noopener"
            data-cmd
            data-label="linkedin"
            class="flex items-center gap-3 rounded-md px-3 py-2 text-sm text-slate-300 aria-selected:bg-surface aria-selected:text-accent"
          >
            <span class="font-mono text-xs text-slate-600">↗</span>
            LinkedIn
          </a>
        </div>
        <div data-item>
          <a
            href={variantPath(other, variant)}
            data-cmd
            data-label={`${t.switchLang[lang].toLowerCase()} langue language fr en`}
            class="flex items-center gap-3 rounded-md px-3 py-2 text-sm text-slate-300 aria-selected:bg-surface aria-selected:text-accent"
          >
            <span class="font-mono text-xs text-slate-600">⇄</span>
            {t.switchLang[lang]}
          </a>
        </div>
      </div>

      <p id="cmdk-empty" class="hidden px-3 py-6 text-center text-sm text-slate-500">···</p>
    </div>
  </div>
</div>

<script>
  const cmdk = document.getElementById('cmdk');
  const input = document.getElementById('cmdk-input') as HTMLInputElement | null;
  const list = document.getElementById('cmdk-list');
  const empty = document.getElementById('cmdk-empty');

  if (cmdk && input && list) {
    let sel = 0;

    const items = () =>
      Array.from(list.querySelectorAll<HTMLElement>('[data-cmd]')).filter(
        (el) => !el.closest<HTMLElement>('[data-item]')?.hidden,
      );

    const select = (n: number) => {
      const its = items();
      if (!its.length) return;
      sel = (n + its.length) % its.length;
      its.forEach((el, i) => el.setAttribute('aria-selected', i === sel ? 'true' : 'false'));
      its[sel].scrollIntoView({ block: 'nearest' });
    };

    const filter = (q: string) => {
      const query = q.trim().toLowerCase();
      list.querySelectorAll<HTMLElement>('[data-item]').forEach((li) => {
        const el = li.querySelector<HTMLElement>('[data-cmd]');
        li.hidden = Boolean(query) && !(el?.dataset.label || '').includes(query);
      });
      list.querySelectorAll<HTMLElement>('[data-group]').forEach((g) => {
        const any = Array.from(g.querySelectorAll<HTMLElement>('[data-item]')).some((li) => !li.hidden);
        g.hidden = !any;
      });
      if (empty) empty.hidden = items().length > 0;
      select(0);
    };

    const isOpen = () => !cmdk.classList.contains('hidden');

    const open = () => {
      cmdk.classList.remove('hidden');
      cmdk.classList.add('flex');
      input.value = '';
      filter('');
      input.focus();
    };

    const close = () => {
      cmdk.classList.add('hidden');
      cmdk.classList.remove('flex');
    };

    window.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        isOpen() ? close() : open();
        return;
      }
      if (!isOpen()) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowDown') {
        e.preventDefault();
        select(sel + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        select(sel - 1);
      } else if (e.key === 'Enter') {
        e.preventDefault();
        items()[sel]?.click();
      }
    });

    input.addEventListener('input', () => filter(input.value));

    cmdk.addEventListener('click', (e) => {
      if (e.target === cmdk) close();
    });

    list.addEventListener('click', (e) => {
      const el = (e.target as HTMLElement).closest<HTMLElement>('[data-cmd]');
      if (!el) return;
      if (el.dataset.copy) {
        e.preventDefault();
        navigator.clipboard?.writeText(el.dataset.copy);
        el.textContent = '✓ ' + el.dataset.copy;
      }
      close();
    });

    document.getElementById('cmdk-open')?.addEventListener('click', open);
  }
</script>
